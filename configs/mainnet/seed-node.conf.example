# Legacy Coin seed/relay node example config
# Seed nodes should not hold hot-wallet funds.

bind=0.0.0.0
node_role=seed
seednode=true
rpcbind=127.0.0.1
rpcuser=legacyseedrpc
rpcpassword=CHANGE-THIS-TO-32+RANDOM-CHARS
seed_peers=true
peer_safety=true
peer_max_inbound=512
peer_max_per_ip=32
peer_max_per_subnet=128

addnode=legacycoinseed.space:19555
addnode=legacycoinseed2.space:19555
addnode=91.219.63.20:19555
