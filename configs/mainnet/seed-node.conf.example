# Legacy Coin seed/relay node example config
# Seed nodes should not hold hot-wallet funds.

bind=0.0.0.0
node_role=seed
seednode=true
rpcbind=127.0.0.1
rpcuser=legacyseedrpc
rpcpassword=CHANGE-THIS-TO-32+RANDOM-CHARS
seed_peers=true
peer_safety=true
peer_max_inbound=512
peer_max_per_ip=32
peer_max_per_subnet=128

addnode=seed1.example.org:19555
addnode=seed2.example.org:19555
addnode=seed3.example.org:19555
